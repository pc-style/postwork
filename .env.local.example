# Created automatically by `bunx convex dev`:
# VITE_CONVEX_URL=https://<your-deployment>.convex.cloud

# Optional: enable Plausible only in the public demo build. The browser also
# verifies that it is running at this exact hostname.
# VITE_PLAUSIBLE_DOMAIN=postwork.pcstyle.dev

# Optional: enable browser error reporting. Without VITE_SENTRY_DSN, Sentry is
# not initialized and local development makes no monitoring network requests.
# VITE_SENTRY_DSN=https://<public-key>@o<org-id>.ingest.sentry.io/<project-id>
# VITE_SENTRY_ENVIRONMENT=development
# VITE_SENTRY_RELEASE=postwork@local

# Optional: enable the Giphy-backed picker in post and reply composers. This is
# a browser-visible key; create one at https://developers.giphy.com/dashboard/.
# VITE_GIPHY_API_KEY=...
