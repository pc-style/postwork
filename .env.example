# Linear API key for linear-pull.mjs and linear-setup-postwork.mjs
# Get one at https://linear.app/settings/account/security
# This file is a template — copy to .env and fill in your key.
# .env is gitignored.
LINEAR_API_KEY=lin_api_your_key_here

# Convex deployment (existing — do not commit real values)
# CONVEX_DEPLOYMENT=anonymous:local

# Clerk (product mode only)
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional: enables GIF search in post and reply composers (client-visible key).
# Create a browser key at https://developers.giphy.com/dashboard/.
# VITE_GIPHY_API_KEY=...

# Outbound email (Convex deployment env, product mode only)
# Configure these with `bunx convex env set NAME value`.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Postwork <notifications@your-verified-domain.example>
# POSTWORK_APP_URL=https://app.example.com
